# Copia este archivo como .env y completa los valores.
# NO subas tu .env real a repositorios públicos.

# Seguridad
SECRET_KEY=pon_aqui_un_valor_largo_aleatorio
FLASK_ADMIN_PASSWORD=pon_aqui_una_contrasena_admin_segura

# Stripe
STRIPE_PUBLIC_KEY=pk_test_o_pk_live
STRIPE_SECRET_KEY=sk_test_o_sk_live
STRIPE_WEBHOOK_SECRET=whsec_tu_secret_del_webhook

# Email (SMTP Gmail con contraseña de aplicación)
EMAIL_SENDER=tu_correo_remitente@gmail.com
EMAIL_PASSWORD=tu_app_password_de_gmail
ADMIN_EMAIL=tu_correo_admin@gmail.com

# Contacto público (opcional)
# WhatsApp: puedes poner +34600111222 o 34600111222
PUBLIC_WHATSAPP_PHONE=
# Instagram: URL completa
PUBLIC_INSTAGRAM_URL=

# Cloudinary (entrega del PDF por enlace)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# HTTPS / proxy (producción)
# Si tu app está detrás de Nginx/Cloudflare, pon normalmente TRUSTED_PROXY_COUNT=1
TRUSTED_PROXY_COUNT=0
# Activa cookies de sesión solo por HTTPS (recomendado en producción)
SESSION_COOKIE_SECURE=0
# Redirige HTTP -> HTTPS dentro de la app (solo si ya tienes HTTPS terminado en el proxy)
ENFORCE_HTTPS=0
# HSTS (solo tiene efecto si SESSION_COOKIE_SECURE=1). Valor en segundos.
HSTS_MAX_AGE=15552000

# Runtime
FLASK_DEBUG=0
PORT=5000
